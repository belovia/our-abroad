<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="005-create-verification" author="you">

        <createTable tableName="verification">
            <column name="id" type="varchar(36)">
                <constraints primaryKey="true"/>
            </column>

            <column name="user_id" type="varchar(36)">
                <constraints nullable="false"/>
            </column>

            <column name="type" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <column name="related_entity_id" type="varchar(36)"/>

            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>

            <column name="verified_at" type="timestamp"/>
        </createTable>

        <createIndex indexName="idx_verification_user"
                     tableName="verification">
            <column name="user_id"/>
        </createIndex>

        <createIndex indexName="idx_verification_user_status"
                     tableName="verification">
            <column name="user_id"/>
            <column name="status"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
